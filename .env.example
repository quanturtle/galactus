# --- Postgres (shared metadata + scraper data) ---
POSTGRES_USER=galactus
POSTGRES_PASSWORD=galactus_secret
POSTGRES_DB=galactus
POSTGRES_PORT=5432

# Used by scraper code (CLI + Airflow tasks). Inside docker-compose, host is `db`;
# for running the CLI on the host, use `localhost`.
DATABASE_URL=postgresql://galactus:galactus_secret@localhost:5432/galactus

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=

AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://galactus:galactus_secret@db:5432/airflow

# Initial admin user (seeded by airflow-init service on first boot).
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# --- MinIO / S3 (image pipeline) ---
# Root credentials for the local MinIO service. Reused as the S3 access/secret
# below so the scraper authenticates against MinIO with the same identity.
MINIO_ROOT_USER=galactus
MINIO_ROOT_PASSWORD=galactus_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# S3 endpoint as seen from inside the docker-compose network (Airflow tasks).
# For host-side CLI runs, override to http://localhost:${MINIO_API_PORT}.
NOTICIAS_S3_ENDPOINT_URL=http://minio:9000
NOTICIAS_S3_ACCESS_KEY=galactus
NOTICIAS_S3_SECRET_KEY=galactus_secret
NOTICIAS_S3_BUCKET=noticias-images
NOTICIAS_S3_REGION=us-east-1

SUPERMERCADOS_S3_ENDPOINT_URL=http://minio:9000
SUPERMERCADOS_S3_ACCESS_KEY=galactus
SUPERMERCADOS_S3_SECRET_KEY=galactus_secret
SUPERMERCADOS_S3_BUCKET=supermercados-images
SUPERMERCADOS_S3_REGION=us-east-1
